{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 -m pytest tests/test_kream_realtime.py tests/test_matcher.py -x -q 2>&1 | tail -5"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/check_claude_md.sh"
          }
        ]
      }
    ]
  }
}
