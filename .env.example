# Discord Bot Token
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Channel IDs
CHANNEL_PROFIT_ALERT=
CHANNEL_PRICE_CHANGE=
CHANNEL_DAILY_REPORT=
CHANNEL_MANUAL_SEARCH=
CHANNEL_SETTINGS=
CHANNEL_LOG=
CHANNEL_MATCH_REVIEW=          # 매칭 검토용 채널 (모델번호 불일치 건 기록)

# Chrome CDP Settings
# Windows Chrome 경로 (WSL에서 접근)
CHROME_PATH=/mnt/c/Program Files/Google/Chrome/Application/chrome.exe
CHROME_DEBUG_PORT=9222
CHROME_USER_DATA_DIR=/mnt/c/Users/USER/AppData/Local/Google/Chrome/User Data/chrome-debug

# 배송비 설정 (원)
SHIPPING_COST_TO_KREAM=3000

# 호카 DataDome 우회 프록시 (미설정 시 직결). 예: http://user:pass@host:port
HOKA_PROXY_URL=

# v3 런타임 (Phase 2.6) — 기본 OFF, 수동 ON 시에만 기동
V3_RUNTIME_ENABLED=false
V3_MUSINSA_INTERVAL_SEC=1800
V3_HOT_POLL_INTERVAL_SEC=60
V3_THROTTLE_RATE_PER_MIN=15
V3_THROTTLE_BURST=20
