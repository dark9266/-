# Discord Bot Token
DISCORD_TOKEN=your_discord_bot_token_here

# Discord Channel IDs
CHANNEL_PROFIT_ALERT=
CHANNEL_PRICE_CHANGE=
CHANNEL_DAILY_REPORT=
CHANNEL_MANUAL_SEARCH=
CHANNEL_SETTINGS=
CHANNEL_LOG=

# Chrome CDP Settings
# Windows Chrome 경로 (WSL에서 접근)
CHROME_PATH=/mnt/c/Program Files/Google/Chrome/Application/chrome.exe
CHROME_DEBUG_PORT=9222
CHROME_USER_DATA_DIR=/mnt/c/Users/USER/AppData/Local/Google/Chrome/User Data/chrome-debug

# 배송비 설정 (원)
SHIPPING_COST_TO_KREAM=3000
